REGISTRY_URL=127.0.0.1
REGISTRY_TYPE=classic
REGISTRY_REPO=
REGISTRY_SSL_VERIFY=False

#application settings
DEBUG=True
SECRET_KEY=iamsecret
PORT=8000
# Comma-separated list of origins (scheme+host) trusted for CSRF-protected POSTs.
# Required as soon as the UI is accessed via HTTPS or a non-localhost hostname.
# Example: CSRF_TRUSTED_ORIGINS=https://dockerui.example.com,https://registry-ui.internal
CSRF_TRUSTED_ORIGINS=

#Authentication credentials to the registry
REGISTRY_USERNAME=
REGISTRY_PASSWORD=

# Admin mode (leave empty to disable admin features)
ADMIN_PASSWORD=